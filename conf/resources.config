def clampCpus = { defaultCpus ->
    params.max_cpus ? Math.min(defaultCpus as int, params.max_cpus as int) : defaultCpus
}

def clampMemory = { defaultMemory ->
    if (!params.max_memory) { return defaultMemory }
    def maxMem = params.max_memory as nextflow.util.MemoryUnit
    def reqMem = defaultMemory as nextflow.util.MemoryUnit
    reqMem > maxMem ? maxMem : reqMem
}

def clampTime = { defaultTime ->
    if (!params.max_time) { return defaultTime }
    def maxDur = params.max_time as nextflow.util.Duration
    def reqDur = defaultTime as nextflow.util.Duration
    reqDur > maxDur ? maxDur : reqDur
}

process {
    withName: 'SPLIT_FASTA' {
        cpus   = clampCpus(1)
        memory = clampMemory('4.GB')
        time   = clampTime('2.h')
    }

    withName: 'CODON_ANALYSIS' {
        cpus   = clampCpus(1)
        memory = clampMemory('8.GB')
        time   = clampTime('6.h')
    }

    withName: 'LONG_ORF' {
        cpus   = clampCpus(1)
        memory = clampMemory('8.GB')
        time   = clampTime('6.h')
    }

    withName: 'TRANSLATE_FASTA' {
        cpus   = clampCpus(1)
        memory = clampMemory('4.GB')
        time   = clampTime('4.h')
    }

    withName: 'HYDROPATHY_PROFILE' {
        cpus   = clampCpus(1)
        memory = clampMemory('4.GB')
        time   = clampTime('4.h')
    }

    withName: 'PLOT_HYDROPATHY' {
        cpus   = clampCpus(1)
        memory = clampMemory('4.GB')
        time   = clampTime('4.h')
    }

    withName: 'HEATMAP_PLOT' {
        cpus   = clampCpus(2)
        memory = clampMemory('8.GB')
        time   = clampTime('2.h')
    }

    withName: 'CODON_PLOTS' {
        cpus   = clampCpus(1)
        memory = clampMemory('4.GB')
        time   = clampTime('2.h')
    }

    withName: 'GATHER_RESULTS' {
        cpus   = clampCpus(2)
        memory = clampMemory('8.GB')
        time   = clampTime('4.h')
    }
}
